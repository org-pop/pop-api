# ==========================================
# DATABASE CONFIGURATION - Aiven PostgreSQL
# ==========================================
DB_HOST=your-aiven-host.e.aivencloud.com
DB_PORT=your-port
DB_NAME=your-database-name
DB_USERNAME=your-username
DB_PASSWORD=your-secure-password

# JDBC URL completa (opcional, mas facilita)
DB_URL=jdbc:postgresql://your-aiven-host.e.aivencloud.com:your-port/your-database-name?sslmode=require

# ==========================================
# JWT CONFIGURATION
# ==========================================
JWT_SECRET=your-jwt-secret-key-with-minimum-32-characters
JWT_EXPIRATION=86400000

# ==========================================
# SPRING PROFILES (opcional)
# ==========================================
SPRING_PROFILES_ACTIVE=prod